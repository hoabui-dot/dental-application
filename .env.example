# ============================================
# Dental CMS - Environment Configuration
# ============================================
#
# Copy this file to .env and update values
# Generate secure keys: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#
# ============================================

# ============================================
# PostgreSQL Database
# ============================================
POSTGRES_DB=dental_cms_strapi
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ============================================
# Strapi CMS
# ============================================

# Server
STRAPI_PORT=1337
STRAPI_PUBLIC_URL=http://localhost:1337

# Secrets (CHANGE THESE IN PRODUCTION!)
STRAPI_APP_KEYS=CHANGE_ME,CHANGE_ME,CHANGE_ME,CHANGE_ME
STRAPI_API_TOKEN_SALT=CHANGE_ME
STRAPI_ADMIN_JWT_SECRET=CHANGE_ME
STRAPI_TRANSFER_TOKEN_SALT=CHANGE_ME
STRAPI_JWT_SECRET=CHANGE_ME

# API Token (Generate in Strapi admin after setup)
STRAPI_API_TOKEN=your-api-token-here

# ============================================
# Next.js Frontend
# ============================================
FRONTEND_PORT=3000
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ============================================
# Development vs Production
# ============================================
NODE_ENV=development
