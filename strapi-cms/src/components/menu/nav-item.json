{
  "collectionName": "components_menu_nav_items",
  "info": {
    "displayName": "NavItem",
    "description": "Navigation item with support for nested children (dropdown)"
  },
  "options": {},
  "attributes": {
    "label": {
      "type": "string",
      "required": true
    },
    "href": {
      "type": "string",
      "required": true
    },
    "children": {
      "type": "component",
      "repeatable": true,
      "component": "menu.nav-child"
    },
    "isExternal": {
      "type": "boolean",
      "default": false
    },
    "icon": {
      "type": "string"
    }
  }
}
