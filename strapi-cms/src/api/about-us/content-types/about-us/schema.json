      "type": "string",
      "required": true,
      "default": "About Us"
    },
    "description": {
      "type": "text"
    },
    "layout": {
      "type": "dynamiczone",
      "components": [
        "about.hero",
        "about.achievements",
        "about.why-choose-us",
        "about.philosophy",
        "about.core-values",
        "about.commitment",
        "about.cta"
      ]
    }
  }
}