# ============================================
# Docker Ignore File - Strapi CMS
# ============================================
#
# Excludes files from Docker build context
# Reduces build time and image size
# ============================================

# Dependencies
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build output
dist/
build/
.cache/

# Uploads (will be in volume)
public/uploads/*

# Environment files
.env
.env.local
.env.development
.env.test
.env.production.local
.env*.local

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Git
.git/
.gitignore
.gitattributes

# Documentation
*.md
!README.md

# Logs
logs/
*.log

# Temporary files
tmp/
temp/

# Docker
Dockerfile*
docker-compose*.yml
.dockerignore

# Database
*.sqlite
*.db

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml

# Misc
.prettierrc
.eslintrc*
.editorconfig
