# ============================================
# Dental CMS - Git Ignore
# ============================================

# ============================================
# Operating Systems
# ============================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
.Spotlight-V100
.Trashes
._*

# Linux
*~

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msm
*.msp

# ============================================
# Node.js
# ============================================

# Dependencies
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# Runtime data
pids
logs
results
lib-cov
lcov.info
.node_history

# ============================================
# Next.js (Frontend)
# ============================================

# Build output
/.next/
/out/
/build
/dental-frontend/.next/
/dental-frontend/.next
/dental-frontend/out/
/dental-frontend/build/

# Testing
/coverage
dental-frontend/coverage/

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Vercel
.vercel

# ============================================
# Strapi (CMS)
# ============================================

# Strapi specific
.strapi/
.strapi-updater.json
.strapi-cloud.json
dist/
build/
exports/
license.txt
strapi-cms/.strapi/
strapi-cms/dist/
strapi-cms/build/
strapi-cms/exports/

# Uploads (keep .gitkeep)
public/uploads/*
strapi-cms/public/uploads/*
!public/uploads/.gitkeep

# ============================================
# Environment Variables
# ============================================

.env
.env.local
.env.development
.env.test
.env.production
.env.docker
.env*
dental-frontend/.env
dental-frontend/.env.local
dental-frontend/.env.production
dental-frontend/.env.docker
strapi-cms/.env
strapi-cms/.env.local

# Keep example files
!.env.example
!dental-frontend/.env.example
!strapi-cms/.env.example

